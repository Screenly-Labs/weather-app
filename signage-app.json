{
  "manifestVersion": "1",
  "id": "weather",
  "name": "Weather",
  "description": "A live weather display with the location, language and clock format you choose.",
  "summary": "Live local weather for any display.",
  "vendor": "Screenly",
  "tags": ["Weather", "Clock"],
  "homepage": "https://weather.srly.io/",
  "source": "https://github.com/Screenly-Labs/weather-app",
  "support": "https://github.com/Screenly-Labs/weather-app/issues",
  "playback": { "duration": 30, "refreshIntervalS": 3600 },
